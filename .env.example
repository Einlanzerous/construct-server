# --- DATADOG ---
DD_API_KEY=your_datadog_api_key_here
DD_SITE=datadoghq.com
DD_TAGS="env:prod host:construct"

# --- OLLAMA ---
# Watchtower is disabled for Ollama to prevent driver mismatch
OLLAMA_BASE_URL=http://ollama:11434

# --- SEMAPHORE UI ---
SEMAPHORE_ADMIN_PASSWORD=change_me
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@localhost
SEMAPHORE_ADMIN=admin

# --- GITHUB (GHCR) ---
GITHUB_USER=Einlanzerous
GITHUB_PAT=ghp_change_me

# --- SERVICE PORTS ---
COOK_BOOK_PORT=4001

# --- POSTGRES ---
POSTGRES_PASSWORD=change_me
COOK_BOOK_DB_PASSWORD=change_me

# --- N8N (Vox-Command) ---
N8N_API_KEY=change_me

# --- ANTHROPIC ---
ANTHROPIC_API_KEY=change_me

# --- GEMINI ---
GEMINI_API_KEY=change_me

# --- DISCORD (Autosavant bot) ---
# Bot token — generated on the "Bot" tab of your Discord Application, NOT the OAuth2 secret
DISCORD_BOT_TOKEN=change_me
DISCORD_GUILD_ID=change_me
# The #imperium-loop text channel ID (right-click channel → Copy Channel ID; enable Developer Mode first)
DISCORD_CHANNEL_ID=change_me
# Optional shared bearer token used by n8n -> autosavant-bot HTTP calls. Leave empty to disable.
AUTOSAVANT_HTTP_TOKEN=
# Base URL for n8n as reachable from autosavant-bot (internal docker hostname is fine)
N8N_PUBLIC_URL=http://n8n:5678

# --- SWITCHYARD ---
SWITCHYARD_DB_PASSWORD=change_me
SWITCHYARD_PORT=4002
SWITCHYARD_PUBLIC_URL=http://localhost:4002
# Admin token (used for project/status/custom-field/rule/webhook setup).
# Prints once on first boot when no api_tokens exist; leave blank to auto-generate.
SWITCHYARD_BOOTSTRAP_TOKEN=
# Per-actor tokens — each pipeline component authenticates as its own Switchyard
# user so the audit log attributes mutations correctly.
#   SWITCHYARD_API_TOKEN              -> n8n-cogitation (Cogitation Engine workflow)
#   SWITCHYARD_TOKEN_N8N_VOX_DICTATE  -> n8n-vox-dictate (Vox-Dictate workflow)
# Inside the n8n container the cogitation token is exposed as SWITCHYARD_TOKEN
# (mapped in docker-compose).
SWITCHYARD_API_TOKEN=
SWITCHYARD_TOKEN_N8N_VOX_DICTATE=
# HMAC secret for the inbound ticket.updated webhook subscription that drives
# the Cogitation Engine. Returned once at subscription creation.
SWITCHYARD_WEBHOOK_SECRET=
# GitHub-side webhook secret for SWY-41 push-mode PR auto-attach (set inside
# the Switchyard container, not n8n).
GITHUB_WEBHOOK_SECRET=

# --- SWITCHYARD E2E TESTING ---
E2E_DATABASE_URL=postgres://switchyard_user:change_me@localhost:5432/switchyard_test
E2E_BOOTSTRAP_TOKEN=
E2E_TEST_USER_TOKEN=

# --- CENTRIFUGE (newsletter curation) ---
# Postgres role/db password — db/init-db.sh provisions centrifuge_user + the
# centrifuge database with this; also injected into the postgres service env.
CENTRIFUGE_DB_PASSWORD=change_me
# Shared secret required on the /ingest endpoints. Senders pass it in the
# X-Ingest-Token header (or ?token=). Leave blank to disable ingest auth.
CENTRIFUGE_INGEST_TOKEN=change_me
# Host port mapped to the container's 8080 (host 8080 is taken by dozzle).
CENTRIFUGE_PORT=4003
# Host port for the Vue reading UI (nginx serves the SPA + proxies to the API).
CENTRIFUGE_WEB_PORT=4004
# Optional overrides (sensible defaults baked into docker-compose.yml):
# CENTRIFUGE_OLLAMA_MODEL=gemma4:31b
# CENTRIFUGE_RELEVANCE_TOPICS=AI engineering,urbanism,transit/trains,nuclear,tech,video games
# Externally reachable base URL for absolute /feed.xml links; blank => per-request.
CENTRIFUGE_PUBLIC_BASE_URL=
# CENTRIFUGE_LOG_LEVEL=info

# --- ARGOSY (media streaming) ---
ARGOSY_PORT=8096
ARGOSY_DB_PASSWORD=change_me
# First-run admin account (created if absent).
ARGOSY_ADMIN_USERNAME=admin
ARGOSY_ADMIN_PASSWORD=change_me
# Periodic library re-scan.
ARGOSY_SCAN_INTERVAL=15m
# Host path to the media library (mounted read-only at /media; copyparty serves /data).
ARGOSY_MEDIA_DIR_HOST=/data/media
# TMDB — metadata + poster/backdrop artwork.
TMDB_API_READ_ACCESS_KEY=change_me
TMDB_API_KEY=change_me
# OpenSubtitles — optional; all three required to enable subtitle download.
OPEN_SUBTITLES_API_KEY=
OPEN_SUBTITLES_USERNAME=
OPEN_SUBTITLES_PASSWORD=

# --- LYCEUM (ebook reader + sync) — LYCM-61 ---
LYCEUM_DB_PASSWORD=change_me
LYCEUM_PORT=4005
# Host path to the books library folder-ingested (mounted read-only at /books).
LYCEUM_BOOKS_DIR_HOST=/data/media/books
# LYCEUM_BOOKS_WATCH_INTERVAL=15
# LYCEUM_COVER_FETCH=true
# Cross-origin native shells (Wails desktop). Blank => same-origin web only.
LYCEUM_CORS_ORIGINS=
# Optional: Eidolon/delivery API tokens + Send-to-Kindle SMTP (LYCM-40x).
LYCEUM_API_TOKENS=
LYCEUM_SMTP_HOST=
LYCEUM_SMTP_PORT=587
LYCEUM_SMTP_USERNAME=
LYCEUM_SMTP_PASSWORD=
LYCEUM_SMTP_FROM=
LYCEUM_KINDLE_ADDR=

# --- PURSER (cross-service provisioning & invite service) — SERV-33 ---
# DB role/db provisioned by db/init-db.sh; password also injected into postgres env.
PURSER_DB_PASSWORD=change_me
PURSER_PORT=4006
# Bearer token protecting Purser's HTTP API (generate: openssl rand -hex 32).
PURSER_API_TOKEN=
# Switchyard connector reuses SWITCHYARD_BOOTSTRAP_TOKEN (see the purser service).
# Cloudflare Access connector (SERV-36) — fill to grant SSO via the API; blank =>
# `--to cloudflare` prints the manual dashboard step. Token scope: Account >
# Access: Organizations, Identity Providers, and Groups: Edit.
PURSER_CF_API_TOKEN=
PURSER_CF_ACCOUNT_ID=
PURSER_CF_ACCESS_GROUP_ID=
# Lyceum connector (SERV-42) — an owner *session* token, not a LYCEUM_API_TOKENS
# entry (those can't reach /admin). One-time: `docker exec lyceum lyceum
# mint-token`, then redeem the lyc_ invite via
# `POST /auth/session {"token":"lyc_…","device_label":"purser"}` and paste the
# returned session_token here. Never expires. Blank => connector Unavailable.
# Requires the lyceum service to run with LYCEUM_AUTH=true.
PURSER_LYCEUM_OWNER_TOKEN=

# --- INTERLOCK (city + state legislation tracker) — ITLK-18 ---
# DB role/db provisioned by db/init-db.sh; password also injected into postgres env.
INTERLOCK_DB_PASSWORD=change_me
# Host port for the web UI/API until the Traefik + tunnel path lands (ITLK-19).
INTERLOCK_PORT=4007
# Session-cookie seal — MUST be >=32 chars (generate: openssl rand -base64 48).
INTERLOCK_SESSION_PASSWORD=
# Login password, scrypt-hashed (generate: `bun run auth:hash` in the interlock repo).
INTERLOCK_AUTH_PASSWORD_HASH=
# Flip to true once Interlock is served over HTTPS (ITLK-19). Leave false while
# reaching it over the plain-HTTP host port, or the session cookie won't come back.
INTERLOCK_AUTH_COOKIE_SECURE=false
# Free LegiScan key for Illinois GA ingest (https://legiscan.com/legiscan). Blank
# => Chicago-only (the Clerk's eLMS needs no key).
INTERLOCK_LEGISCAN_API_KEY=
# Optional email alerts (blank => in-app only). SMTP URL e.g. smtp://user:pass@host:587
INTERLOCK_SMTP_URL=
INTERLOCK_ALERT_EMAIL_TO=
INTERLOCK_ALERT_EMAIL_FROM=
# Sponsor auto-link pg_trgm threshold, shared by ingest + UI (default 0.85).
# INTERLOCK_MATCH_THRESHOLD=0.85

# --- ZERO GRAVITY INDUSTRIES — HYBRID EDGE (SERV-19/20/21) ---
# Traefik ACME DNS-01: scoped Cloudflare API token, Zone:DNS:Edit on the
# zerogravity.industries zone ONLY. Mint alongside the domain (SERV-14); until it
# is set, Traefik starts and routes but issues no certs.
CF_DNS_API_TOKEN=

# Cloudflare Tunnel (SERV-23). Dashboard-managed (token) tunnel; the connector
# token encodes the tunnel ID, so the container only needs the token. TUNNEL_ID is
# kept for reference (DNS/CNAME targets, dashboard lookups).
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
# cloudflared floats on `latest` (Cloudflare deprecates old builds); pin + bump
# deliberately since watchtower is disabled for it.
CLOUDFLARED_TAG=latest

# Authentik (SERV-19). Runs on the shared postgres (authentik DB provisioned by
# db/init-db.sh) + a dedicated Redis.
# AUTHENTIK_TAG floats on `stable`; pin a specific version (e.g. 2025.6.x) before
# treating this as production so upgrades are deliberate.
AUTHENTIK_TAG=stable
# Postgres role/db password — also injected into the postgres service env.
AUTHENTIK_DB_PASSWORD=change_me
# Instance secret key — generate with:  openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=change_me
# First-boot admin (akadmin) bootstrap — consumed only on the initial DB init.
AUTHENTIK_BOOTSTRAP_EMAIL=admin@zerogravity.industries
AUTHENTIK_BOOTSTRAP_PASSWORD=change_me
# Optional API token for the bootstrap admin (blank => none created).
AUTHENTIK_BOOTSTRAP_TOKEN=
